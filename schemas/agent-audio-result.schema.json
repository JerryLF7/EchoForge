{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echoforge.local/schemas/agent-audio-result.schema.json",
  "title": "Host Agent Audio Understanding Result",
  "type": "object",
  "required": [
    "language",
    "summary",
    "transcriptUtterances",
    "obsidianTranscriptMarkdown"
  ],
  "properties": {
    "language": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "transcriptUtterances": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["speaker", "start", "end", "text", "notes"],
        "properties": {
          "speaker": {
            "type": ["string", "null"]
          },
          "start": {
            "oneOf": [
              {
                "type": "number",
                "minimum": 0
              },
              {
                "type": "string",
                "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]+)?$"
              }
            ]
          },
          "end": {
            "oneOf": [
              {
                "type": "number",
                "minimum": 0
              },
              {
                "type": "string",
                "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]+)?$"
              }
            ]
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "obsidianTranscriptMarkdown": {
      "type": "string",
      "minLength": 1
    },
    "agent": {
      "type": "object",
      "properties": {
        "host": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "sessionId": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
