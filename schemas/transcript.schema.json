{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echoforge.local/schemas/transcript.schema.json",
  "title": "Transcript",
  "type": "object",
  "required": ["recordingId", "language", "utterances"],
  "properties": {
    "recordingId": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "utterances": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["utteranceId", "start", "end", "text"],
        "properties": {
          "utteranceId": {
            "type": "string"
          },
          "speaker": {
            "type": "string"
          },
          "start": {
            "type": "number",
            "minimum": 0
          },
          "end": {
            "type": "number",
            "minimum": 0
          },
          "text": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": false
      }
    },
    "provider": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "model": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
