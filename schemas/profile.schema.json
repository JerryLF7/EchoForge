{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echoforge.local/schemas/profile.schema.json",
  "title": "EchoForge Profile",
  "type": "object",
  "required": [
    "id",
    "label",
    "promptProfile",
    "outputPreset",
    "audioUnderstanding",
    "sections",
    "todosEnabled"
  ],
  "properties": {
    "id": { "type": "string" },
    "label": { "type": "string" },
    "promptProfile": { "type": "string" },
    "outputPreset": { "type": "string" },
    "language": { "type": "string" },
    "audioUnderstanding": {
      "type": "object",
      "required": ["provider", "model", "capabilities", "prompt", "terminologyHints"],
      "properties": {
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "capabilities": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "prompt": { "type": "string" },
        "terminologyHints": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "sections": {
      "type": "array",
      "items": { "type": "string" }
    },
    "todosEnabled": { "type": "boolean" }
  },
  "additionalProperties": false
}
