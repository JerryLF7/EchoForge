# Provider selection
ECHOFORGE_UNDERSTANDING_PROVIDER=tingwu

# Tingwu
TINGWU_ACCESS_KEY_ID=your_access_key_id
TINGWU_ACCESS_KEY_SECRET=your_a...cret
TINGWU_APP_KEY=your_tingwu_app_key
TINGWU_REGION=cn-beijing
TINGWU_ENDPOINT=https://tingwu.cn-beijing.aliyuncs.com
TINGWU_LANGUAGE=auto

# Doubao ASR
DOUBAO_APP_KEY=your_doubao_app_key
DOUBAO_ACCESS_KEY=your_doubao_access_key
DOUBAO_RESOURCE_ID=volc.lark.minutes
DOUBAO_SUBMIT_URL=https://openspeech.bytedance.com/api/v3/auc/lark/submit
DOUBAO_QUERY_URL=https://openspeech.bytedance.com/api/v3/auc/lark/query
DOUBAO_SOURCE_LANG=zh_cn
DOUBAO_SPEAKER_IDENTIFICATION=true
DOUBAO_NUMBER_OF_SPEAKERS=0
DOUBAO_NEED_WORD_TIME_SERIES=true

# Doubao Speech (standard edition — api/v1/auc, up to 5h)
DOUBAO_SPEECH_APPID=your_appid
DOUBAO_SPEECH_TOKEN=your_token
DOUBAO_SPEECH_CLUSTER=your_cluster_id
DOUBAO_SPEECH_UID=echoforge

# Cloudflare R2 (optional, for local file transit)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=echoforge-transit
R2_PRESIGNED_EXPIRY=10800

# Gemini direct audio experiment
GEMINI_API_KEY=your_gemini_api_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-3-flash-preview

# Local paths
ECHOFORGE_OUTPUTS_DIR=./outputs
OBSIDIAN_VAULT_PATH=/path/to/obsidian/vault
FEISHU_MINUTES_SYNC_BIN=feishu-minutes-sync
FEISHU_MINUTES_SYNC_EXPORTS_DIR=./exports

# Behavior
ECHOFORGE_DEFAULT_TEMPLATE=full
ECHOFORGE_POLL_INTERVAL_SECONDS=5
ECHOFORGE_POLL_SLOW_INTERVAL_SECONDS=15
ECHOFORGE_POLL_TIMEOUT_SECONDS=600
