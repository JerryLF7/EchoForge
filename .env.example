# Tingwu
TINGWU_ACCESS_KEY_ID=your_access_key_id
TINGWU_ACCESS_KEY_SECRET=your_access_key_secret
TINGWU_APP_KEY=your_tingwu_app_key
TINGWU_REGION=cn-beijing
TINGWU_ENDPOINT=https://tingwu.cn-beijing.aliyuncs.com
TINGWU_LANGUAGE=auto

# Local paths
ECHOFORGE_OUTPUTS_DIR=./outputs
OBSIDIAN_VAULT_PATH=/path/to/obsidian/vault
FEISHU_MINUTES_SYNC_BIN=feishu-minutes-sync
FEISHU_MINUTES_SYNC_EXPORTS_DIR=./exports

# Behavior
ECHOFORGE_DEFAULT_TEMPLATE=full
ECHOFORGE_POLL_INTERVAL_SECONDS=5
ECHOFORGE_POLL_SLOW_INTERVAL_SECONDS=15
ECHOFORGE_POLL_TIMEOUT_SECONDS=600
