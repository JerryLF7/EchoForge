{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echoforge.local/schemas/agent-audio-task.schema.json",
  "title": "Host Agent Audio Understanding Task",
  "type": "object",
  "required": [
    "taskSchema",
    "taskKind",
    "taskVersion",
    "recording",
    "profile",
    "guidance",
    "resultContract"
  ],
  "properties": {
    "taskSchema": {
      "type": "string",
      "const": "agent-audio-task.schema.json"
    },
    "taskKind": {
      "type": "string",
      "const": "audio_understanding"
    },
    "taskVersion": {
      "type": "string",
      "const": "2026-03-17"
    },
    "recording": {
      "type": "object",
      "required": [
        "recordingId",
        "title",
        "capturedAt",
        "audio",
        "participants",
        "source"
      ],
      "properties": {
        "recordingId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "capturedAt": {
          "type": "string",
          "format": "date-time"
        },
        "audio": {
          "type": "object",
          "required": ["path", "format"],
          "properties": {
            "path": {
              "type": "string"
            },
            "format": {
              "type": "string"
            },
            "durationSeconds": {
              "type": "number",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "participants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string"
              },
              "role": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "source": {
          "type": "object",
          "required": ["kind", "itemId"],
          "properties": {
            "kind": {
              "type": "string"
            },
            "itemId": {
              "type": "string"
            },
            "workspace": {
              "type": ["string", "null"]
            },
            "url": {
              "type": ["string", "null"],
              "format": "uri"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "profile": {
      "type": "object",
      "required": ["id", "promptProfile", "outputPreset", "language"],
      "properties": {
        "id": {
          "type": "string"
        },
        "promptProfile": {
          "type": "string"
        },
        "outputPreset": {
          "type": "string"
        },
        "language": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "guidance": {
      "type": "object",
      "required": [
        "scenarioPrompt",
        "terminologyHints",
        "transcriptMode",
        "obsidianMode",
        "timestampGuidance",
        "speakerGuidance"
      ],
      "properties": {
        "scenarioPrompt": {
          "type": "string"
        },
        "terminologyHints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transcriptMode": {
          "type": "string"
        },
        "obsidianMode": {
          "type": "string"
        },
        "timestampGuidance": {
          "type": "string"
        },
        "speakerGuidance": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "resultContract": {
      "type": "object",
      "required": [
        "schema",
        "contentType",
        "requiredFields",
        "transcriptUtteranceFields",
        "optionalAgentMetadataFields"
      ],
      "properties": {
        "schema": {
          "type": "string",
          "const": "agent-audio-result.schema.json"
        },
        "contentType": {
          "type": "string",
          "const": "application/json"
        },
        "requiredFields": {
          "const": [
            "language",
            "summary",
            "transcriptUtterances",
            "obsidianTranscriptMarkdown"
          ]
        },
        "transcriptUtteranceFields": {
          "const": [
            "speaker",
            "start",
            "end",
            "text",
            "notes"
          ]
        },
        "optionalAgentMetadataFields": {
          "const": [
            "host",
            "model",
            "sessionId"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
