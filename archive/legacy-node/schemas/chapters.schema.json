{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echoforge.local/schemas/chapters.schema.json",
  "title": "Chapter Timeline",
  "type": "object",
  "required": ["recordingId", "sourceTranscript", "chapters"],
  "properties": {
    "recordingId": {
      "type": "string"
    },
    "sourceTranscript": {
      "type": "object",
      "required": ["contentRole", "providerKind"],
      "properties": {
        "contentRole": {
          "type": "string",
          "enum": ["machine_transcript"]
        },
        "providerKind": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["chapterId", "title", "start", "end", "summary"],
        "properties": {
          "chapterId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "start": {
            "type": "number",
            "minimum": 0
          },
          "end": {
            "type": "number",
            "minimum": 0
          },
          "summary": {
            "type": "string"
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
