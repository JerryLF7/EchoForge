{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echoforge.local/schemas/transcript.schema.json",
  "title": "Understood Transcript",
  "type": "object",
  "required": ["recordingId", "contentRole", "language", "mode", "utterances", "provider", "understanding"],
  "properties": {
    "recordingId": {
      "type": "string"
    },
    "contentRole": {
      "type": "string",
      "enum": ["machine_transcript"]
    },
    "language": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": ["audio_understanding"]
    },
    "summary": {
      "type": "string"
    },
    "utterances": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["utteranceId", "start", "end", "text"],
        "properties": {
          "utteranceId": {
            "type": "string"
          },
          "speaker": {
            "type": "string"
          },
          "start": {
            "type": "number",
            "minimum": 0
          },
          "end": {
            "type": "number",
            "minimum": 0
          },
          "text": {
            "type": "string"
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "provider": {
      "type": "object",
      "required": ["kind", "name", "model"],
      "properties": {
        "kind": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "model": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "understanding": {
      "type": "object",
      "required": ["promptProfile", "scenarioPrompt", "terminologyHints", "speakerInference"],
      "properties": {
        "promptProfile": {
          "type": "string"
        },
        "scenarioPrompt": {
          "type": "string"
        },
        "terminologyHints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "speakerInference": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
